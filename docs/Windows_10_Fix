# --------------------------------------------------------

Write-Host "[*] Enabling VBS / Credential Guard..."

Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\DeviceGuard" "EnableVirtualizationBasedSecurity" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\DeviceGuard" "RequirePlatformSecurityFeatures" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa" "LsaCfgFlags" DWord 1


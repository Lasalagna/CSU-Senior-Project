# --------------------------------------------------------
# Helper
# --------------------------------------------------------

function Set-RegValue {
    param(
        [string]$Path,
        [string]$Name,
        [string]$Type,
        $Value
    )

    if (!(Test-Path $Path)) {
        New-Item -Path $Path -Force | Out-Null
    }

    New-ItemProperty `
        -Path $Path `
        -Name $Name `
        -PropertyType $Type `
        -Value $Value `
        -Force | Out-Null
}

# --------------------------------------------------------
# Disable Insecure Features
# --------------------------------------------------------

Write-Host "[*] Disabling insecure Windows features..."

Disable-WindowsOptionalFeature -Online -FeatureName MicrosoftWindowsPowerShellV2Root -NoRestart -ErrorAction SilentlyContinue
Disable-WindowsOptionalFeature -Online -FeatureName SMB1Protocol -NoRestart -ErrorAction SilentlyContinue
Disable-WindowsOptionalFeature -Online -FeatureName WorkFolders-Client -NoRestart -ErrorAction SilentlyContinue

# --------------------------------------------------------
# Autoplay / Autorun
# --------------------------------------------------------

Write-Host "[*] Configuring Autoplay / Autorun..."

Set-RegValue "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\Explorer" "NoAutorun" DWord 1
Set-RegValue "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\Explorer" "NoDriveTypeAutoRun" DWord 255
Set-RegValue "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\Explorer" "NoAutoplayfornonVolume" DWord 1

# --------------------------------------------------------
# Remote Assistance
# --------------------------------------------------------

Write-Host "[*] Disabling Remote Assistance..."

Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Remote Assistance" "fAllowToGetHelp" DWord 0

# --------------------------------------------------------
# DEP
# --------------------------------------------------------

Write-Host "[*] Enabling DEP..."

bcdedit /set "{current}" nx OptOut

# --------------------------------------------------------
# WDigest
# --------------------------------------------------------

Write-Host "[*] Disabling WDigest..."

Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\SecurityProviders\WDigest" "UseLogonCredential" DWord 0

# --------------------------------------------------------
# WinRM
# --------------------------------------------------------

Write-Host "[*] Hardening WinRM..."

Set-RegValue "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WinRM\Client" "AllowBasic" DWord 0
Set-RegValue "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WinRM\Service" "AllowBasic" DWord 0
Set-RegValue "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WinRM\Client" "AllowDigest" DWord 0
Set-RegValue "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WinRM\Client" "AllowUnencryptedTraffic" DWord 0
Set-RegValue "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WinRM\Service" "AllowUnencryptedTraffic" DWord 0
Set-RegValue "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WinRM\Service" "DisableRunAs" DWord 1

# --------------------------------------------------------
# NTLM / LSA
# --------------------------------------------------------

Write-Host "[*] Hardening NTLM / LSA..."

Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa" "LmCompatibilityLevel" DWord 5
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa" "RestrictAnonymous" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa" "RestrictAnonymousSAM" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa" "EveryoneIncludesAnonymous" DWord 0
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa" "NoLMHash" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa\MSV1_0" "NTLMMinClientSec" DWord 537395200
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Control\Lsa\MSV1_0" "NTLMMinServerSec" DWord 537395200

# --------------------------------------------------------
# SMB
# --------------------------------------------------------

Write-Host "[*] Hardening SMB..."

Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters" "RequireSecuritySignature" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Services\LanmanServer\Parameters" "RequireSecuritySignature" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters" "EnableSecuritySignature" DWord 1
Set-RegValue "HKLM:\SYSTEM\CurrentControlSet\Services\LanmanServer\Parameters" "EnableSecuritySignature" DWord 1

# --------------------------------------------------------
# UAC
# --------------------------------------------------------

Write-Host "[*] Configuring UAC..."

$uac = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System"

Set-RegValue $uac "EnableLUA" DWord 1
Set-RegValue $uac "ConsentPromptBehaviorAdmin" DWord 2
Set-RegValue $uac "ConsentPromptBehaviorUser" DWord 0
Set-RegValue $uac "PromptOnSecureDesktop" DWord 1
Set-RegValue $uac "EnableInstallerDetection" DWord 1
Set-RegValue $uac "FilterAdministratorToken" DWord 1

# --------------------------------------------------------
# Password Policies
# --------------------------------------------------------

Write-Host "[*] Applying password policy..."

net accounts /minpwlen:14
net accounts /maxpwage:60
net accounts /minpwage:1
net accounts /uniquepw:24

# --------------------------------------------------------
# Account Lockout
# --------------------------------------------------------

Write-Host "[*] Applying lockout policy..."

net accounts /lockoutthreshold:3
net accounts /lockoutduration:15
net accounts /lockoutwindow:15

